<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_raw">
    
        <xpath expr="//t[@t-foreach='docs']" position="replace">
            <t t-foreach="docs" t-as="o"></t>
                <div class="page">

                    <div style="display:flex; justify-content:space-between;">
                        
                        <div>

                            <img t-if="company.logo"
                                t-att-src="'data:image/png;base64,%s' % company.logo"
                                style="max-height:100px;"/>
                            
                            <h2><span t-out="company.name"/></h2>

                            <p>
                                <span t-out="o.partner_id.name"/><br/>
                                <span t-out="o.partner_id.email"/><br/>
                                <span t-out="o.partner_id.phone"/>
                            </p>
                        </div>
                        <div>
                            <span t-out="o.date_order"/>
                        </div>
                    </div> 
            

            <br/><br/>

                <!-- TABLA -->
             <table style="width:100%; border-collapse:collapse;">
                <thead style="background:#6c6c6c; color:white;">
                    <tr>
                        <th>Descripción</th>
                        <th>Cantidad</th>
                        <th>Und</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="o.order_line" t-as="line">
                        <td><span t-out="line.name"/></td>
                        <td class="text-center">
                            <span t-out="line.product_uom_qty"/>
                        </td>
                        <td class="text-center">
                            <span t-out="line.product_uom.name"/>
                        </td>
                        <td class="text-right">
                            <span t-out="line.price_total"/>
                        </td>
                    </tr>
                </tbody>
             </table>
             <br/><br/>

                <!-- TOTALES -->
            <div style="width:40%; float:right;">
                <p><strong>SUBTOTAL</strong>
                    <span t-out="o.amount_untaxed"/>
                </p>

                <p><strong>DESCUENTO</strong>
                    <span t-esc="sum(line.price_subtotal * line.discount / 100 for line in o.order_line)"/>                
                </p>
                
                <div style="background:#6c6c6c; color:white; padding: 10px;">
                    <strong>TOTAL:</strong>
                    <span t-out="o.amount_total"/>
                </div>
            </div>
            <br/><br/><br/>

                <!-- NOTA-->
                <div>
                    <strong>Nota:</strong>
                    <p>
                        La cotización es válida por 7 días.
                        La fecha de ejecución del servicio se considerará segun disponibilidad.
                    </p>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
