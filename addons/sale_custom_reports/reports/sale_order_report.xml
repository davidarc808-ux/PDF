<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document" priority="99">
        <xpath expr="//div[hasclass('page')]" position="replace">
            <div class="page">
                <style>
                    .table-header { background-color: #6c757d !important; color: white !important; }
                    .table-striped tbody tr:nth-of-type(odd) { background-color: #f2f2f2; }
                    .total-box { background-color: #6c757d; color: white; padding: 10px; font-weight: bold; }
                </style>

                <div class="row">
                    <div class="col-6">
                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" style="max-height: 80px;"/>
                        <h3><span t-field="doc.company_id.name"/></h3>
                    </div>
                </div>

                <table class="table table-sm mt-4">
                    <thead class="table-header">
                        <tr>
                            <th>Descripción</th>
                            <th class="text-center" name="th_quantity">Cantidad</th>
                            <th class="text-center">Unidad</th>
                            <th name="th_discount">Descuentos</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody class="table-striped">
                        <tr t-foreach="doc.order_line" t-as="line">
                            <td><span t-field="line.name"/></td>
                            <td class="text-center" name="td_product_quantity"><span t-field="line.product_uom_qty"/></td>
                            <td class="text-center"><span t-if="line.product_uom_id" t-field="line.product_uom_id.name"/></td>
                            <td name="td_product_discount"></td>
                            <td class="text-end">
                                <span t-field="line.price_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="row justify-content-end mt-4">
                    <div class="col-4">
                        <table class="table table-sm">
                            <tr><td>Subtotal</td><td class="text-end"><span t-field="doc.amount_untaxed"/></td></tr>
                            <tr class="total-box"><td>TOTAL</td><td class="text-end"><span t-field="doc.amount_total"/></td></tr>
                        </table>
                    </div>
                </div>

                <div id="informations">
                </div>
            </div>
        </xpath>
    </template>
</odoo>